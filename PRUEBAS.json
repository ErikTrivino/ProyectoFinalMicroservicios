        },
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "json",
          "raw": "{\n  \"email\": \"juan@empresa.com\"\n}"
        }
      },
      "tests": [
        "pm.test('Status 200', function() { pm.response.to.have.status(200); });"
      ]
    },
    {
      "uid": "12-validate-token",
      "name": "✓ Validar Token",
      "request": {
        "method": "POST",
        "url": {
          "raw": "http://localhost:8082/auth/validate",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8082",
          "path": ["auth", "validate"]
        },
        "headers": [
          {
            "key": "Content-Type",
