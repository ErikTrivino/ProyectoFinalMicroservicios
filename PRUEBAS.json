{
  "client": "Bruno",
  "version": "1.0.0",
  "name": "Microservicios JWT - Pruebas",
  "items": [
    {
      "uid": "01-registrar-usuario",
      "name": "1️⃣ Registrar Usuario",
      "request": {
        "method": "POST",
        "url": {
          "raw": "http://localhost:8082/auth/register",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8082",
          "path": ["auth", "register"]
        },
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "json",
          "raw": "{\n  \"username\": \"juan_perez\",\n  \"email\": \"juan@empresa.com\",\n  \"password\": \"SecurePass123\"\n}"
        }
      },
      "tests": [
        "pm.test('Status 201', function() { pm.response.to.have.status(201); });",
        "pm.test('Tiene access_token', function() { pm.expect(pm.response.json().data.username).to.eql('juan_perez'); });"
      ]
    },
    {
      "uid": "02-login-admin",
      "name": "2️⃣ Login ADMIN (Por Defecto)",
      "request": {
        "method": "POST",
        "url": {
          "raw": "http://localhost:8082/auth/login",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8082",
          "path": ["auth", "login"]
        },
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "json",
          "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
        }
      },
      "tests": [
        "pm.test('Status 200', function() { pm.response.to.have.status(200); });",
        "pm.test('Retorna token', function() { pm.expect(pm.response.json().data.access_token).to.be.a('string'); });",
        "pm.test('Rol es ADMIN', function() { pm.expect(pm.response.json().data.role).to.eql('ADMIN'); });",
        "pm.globals.set('admin_token', pm.response.json().data.access_token);"
      ]
    },
    {
      "uid": "03-login-user-registrado",
      "name": "3️⃣ Login Usuario Registrado",
      "request": {
        "method": "POST",
        "url": {
          "raw": "http://localhost:8082/auth/login",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8082",
          "path": ["auth", "login"]
        },
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "json",
          "raw": "{\n  \"username\": \"juan_perez\",\n  \"password\": \"SecurePass123\"\n}"
        }
      },
      "tests": [
        "pm.test('Status 200', function() { pm.response.to.have.status(200); });",
        "pm.test('Retorna token', function() { pm.expect(pm.response.json().data.access_token).to.be.a('string'); });",
        "pm.test('Rol es USER', function() { pm.expect(pm.response.json().data.role).to.eql('USER'); });",
        "pm.globals.set('user_token', pm.response.json().data.access_token);"
      ]
    },
    {
      "uid": "04-get-empleados-con-token",
      "name": "4️⃣ GET /empleados (Con Token ADMIN)",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:8080/empleados",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["empleados"]
        },
        "headers": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}"
          }
        ]
      },
      "tests": [
        "pm.test('Status 200', function() { pm.response.to.have.status(200); });",
        "pm.test('Retorna array', function() { pm.expect(pm.response.json().data).to.be.an('array'); });"
      ]
    },
    {
      "uid": "05-get-empleados-user-token",
      "name": "5️⃣ GET /empleados (Con Token USER)",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:8080/empleados",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["empleados"]
        },
        "headers": [
          {
            "key": "Authorization",
            "value": "Bearer {{user_token}}"
          }
        ]
      },
      "tests": [
        "pm.test('Status 200 - USER puede leer', function() { pm.response.to.have.status(200); });"
      ]
    },
    {
      "uid": "06-get-empleados-sin-token",
      "name": "6️⃣ GET /empleados (SIN Token) ❌ Debe Fallar",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:8080/empleados",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["empleados"]
        }
      },
      "tests": [
        "pm.test('Status 401 - Sin token debe fallar', function() { pm.response.to.have.status(401); });"
      ]
    },
    {
      "uid": "07-post-empleados-admin",
      "name": "7️⃣ POST /empleados (ADMIN) ✅ Crear",
      "request": {
        "method": "POST",
        "url": {
          "raw": "http://localhost:8080/empleados",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["empleados"]
        },
        "headers": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "json",
          "raw": "{\n  \"nombre\": \"Maria Garcia\",\n  \"departamento_id\": \"D001\"\n}"
        }
      },
      "tests": [
        "pm.test('Status 201 - ADMIN puede crear', function() { pm.response.to.have.status(201); });"
      ]
    },
    {
      "uid": "08-post-empleados-user",
      "name": "8️⃣ POST /empleados (USER) ❌ Debe Fallar 403",
      "request": {
        "method": "POST",
        "url": {
          "raw": "http://localhost:8080/empleados",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["empleados"]
        },
        "headers": [
          {
            "key": "Authorization",
            "value": "Bearer {{user_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "json",
          "raw": "{\n  \"nombre\": \"Test\",\n  \"departamento_id\": \"D001\"\n}"
        }
      },
      "tests": [
        "pm.test('Status 403 - USER no puede crear', function() { pm.response.to.have.status(403); });"
      ]
    },
    {
      "uid": "09-delete-empleados-user",
      "name": "9️⃣ DELETE /empleados (USER) ❌ Debe Fallar 403",
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "http://localhost:8080/empleados/E001",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["empleados", "E001"]
        },
        "headers": [
          {
            "key": "Authorization",
            "value": "Bearer {{user_token}}"
          }
        ]
      },
      "tests": [
        "pm.test('Status 403 - USER no puede eliminar', function() { pm.response.to.have.status(403); });"
      ]
    },
    {
      "uid": "10-delete-empleados-admin",
      "name": "🔟 DELETE /empleados (ADMIN) ✅ Eliminar",
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "http://localhost:8080/empleados/E001",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["empleados", "E001"]
        },
        "headers": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}"
          }
        ]
      },
      "tests": [
        "pm.test('Status 200 o 204 - ADMIN puede eliminar', function() { pm.expect([200, 204]).to.include(pm.response.code); });"
      ]
    },
    {
      "uid": "11-recover-password",
      "name": "🔑 Recuperar Contraseña",
      "request": {
