          }
        ],
        "body": {
          "mode": "json",
          "raw": "{\n  \"token\": \"{{admin_token}}\"\n}"
        }
      },
      "tests": [
        "pm.test('Token válido', function() { pm.response.to.have.status(200); });"
      ]
    },
    {
