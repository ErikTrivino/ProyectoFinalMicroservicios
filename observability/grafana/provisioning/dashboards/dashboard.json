{
  "uid": "microservicios-observabilidad",
  "title": "Observabilidad Microservicios",
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "15s",
  "panels": [
    {
      "type": "row",
      "title": "1. Resumen del Sistema",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "id": 100
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Estado de cada servicio",
      "gridPos": { "x": 0, "y": 1, "w": 24, "h": 6 },
      "targets": [
        {
          "expr": "up",
          "refId": "A",
          "legendFormat": "{{job}}"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": { "color": "red", "index": 1, "text": "Caído" },
                "1": { "color": "green", "index": 0, "text": "Activo" }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "type": "row",
      "title": "2. Comportamiento del Tráfico",
      "gridPos": { "x": 0, "y": 7, "w": 24, "h": 1 },
      "id": 200
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Tasa de peticiones por servicio",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "sum by (job) (rate(flask_http_request_total[1m]) or rate(http_requests_received_total[1m]) or rate(http_server_requests_seconds_count[1m]))",
          "refId": "A",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Latencia promedio",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "sum by (job) (rate(flask_http_request_duration_seconds_sum[1m]) / rate(flask_http_request_duration_seconds_count[1m]) or rate(http_request_duration_seconds_sum[1m]) / rate(http_request_duration_seconds_count[1m]) or rate(http_server_requests_seconds_sum[1m]) / rate(http_server_requests_seconds_count[1m]))",
          "refId": "A",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Errores HTTP (4xx y 5xx)",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "sum by (status, code) (rate(flask_http_request_total{code=~\"[45]..\"}[1m]) or rate(http_requests_received_total{status=~\"[45]..\"}[1m]) or rate(http_server_requests_seconds_count{status=~\"[45]..\"}[1m]))",
          "refId": "A",
          "legendFormat": "{{status}}{{code}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    }
  ]
}
