# ========== JWT Configuration ==========
# Clave secreta para firmar y validar tokens JWT
# ⚠️ IMPORTANTE: En producción, cambiar a una clave segura y aleatoria
# Ejemplo: openssl rand -base64 32
JWT_SECRET=supersecreto_cambiar_en_produccion

# Algoritmo de firma JWT (recomendado: HS256 para ambiente académico)
# En producción, usar RS256 (asimétrico)
JWT_ALGORITHM=HS256

# Tiempo de expiración de tokens de acceso (en minutos)
ACCESS_TOKEN_EXPIRES_MINUTES=60

# Tiempo de expiración de tokens de recuperación de contraseña (en minutos)
RESET_TOKEN_EXPIRES_MINUTES=60

# ========== Database Configuration ==========
# Configuración para el servicio de autenticación

# Host de la base de datos PostgreSQL
DB_HOST=database-auth

# Puerto de conexión
DB_PORT=5432

# Nombre de la base de datos
DB_NAME=auth_db

# Usuario de la base de datos
DB_USER=auth_user

# Contraseña del usuario de base de datos
# ⚠️ En producción, usar un valor seguro
DB_PASSWORD=auth_pass

# ========== RabbitMQ Configuration ==========
# URL de conexión a RabbitMQ
# Formato: amqp://usuario:contraseña@host:puerto
RABBITMQ_URL=amqp://admin:admin@message-broker:5672

# ========== Auth-Service Configuration ==========
# Credenciales del usuario administrador "seed" (creado al iniciar)
AUTH_ADMIN_USER=admin
AUTH_ADMIN_PASSWORD=admin123

# Credenciales del usuario por defecto (seed)
AUTH_DEFAULT_USER=user
AUTH_DEFAULT_PASSWORD=user123

# ========== Otros Servicios ==========
# Estas variables se heredan en todos los contenedores para compatibilidad
# de validación de tokens entre servicios

# URL del servicio de autenticación
AUTH_SERVICE_URL=http://auth-service:80

# Puerto en el que escucha cada servicio
EMPLEADOS_SERVICE_PORT=8080
DEPARTAMENTOS_SERVICE_PORT=8081
NOTIFICACIONES_SERVICE_PORT=3000
