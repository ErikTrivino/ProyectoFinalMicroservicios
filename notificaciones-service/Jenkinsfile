// ============================================================
// Jenkinsfile - notificaciones-service (C#/.NET 10)
// Reto 6 - Integración Continua
// ============================================================
// Pipeline declarativo con etapas:
//   Checkout → Build → Test → SonarQube → Quality Gate →
//   Package → Publish → E2E Tests
// ============================================================

pipeline {
    agent any

    // ========================================
    // Trigger: se dispara al detectar cambios en Git
    // ========================================
    triggers {
        pollSCM('H/5 * * * *')
    }

    environment {
        SERVICE_NAME = 'notificaciones-service'
        IMAGE_NAME   = 'proyecto-notificaciones'
        REGISTRY     = 'localhost:5000'
        SONAR_TOKEN  = credentials('sonar-token')
    }

    stages {

        // ========================================
        // ETAPA 1: Checkout
        // ========================================
        stage('Checkout') {
            steps {
                echo "📥 Obteniendo código fuente de ${SERVICE_NAME}..."
                sh "mkdir -p ${SERVICE_NAME}"
                sh "cp -r /var/jenkins_home/workspace-config/${SERVICE_NAME}/* ./${SERVICE_NAME}/"
                sh "mkdir -p NotificacionesService.Tests"
                sh "cp -r /var/jenkins_home/workspace-config/NotificacionesService.Tests/* ./NotificacionesService.Tests/"
                sh "cp /var/jenkins_home/workspace-config/ProyectoFinalMicroservicios.sln . || true"
                sh "cp -r /var/jenkins_home/workspace-config/pruebas-funcionales ./pruebas-funcionales || true"
                sh "cp /var/jenkins_home/workspace-config/docker-compose.yml . || true"
                sh "cp -r /var/jenkins_home/workspace-config/jenkins ./jenkins || true"
                sh 'ls -la'
            }
        }

        // ========================================
        // ETAPA 2: Build
        // ========================================
        stage('Build') {
            agent {
                docker {
                    image 'mcr.microsoft.com/dotnet/sdk:10.0'
                    reuseNode true
                }
            }
            steps {
                echo "🔨 Compilando ${SERVICE_NAME} con .NET..."
                sh 'dotnet restore'
                sh 'dotnet build -c Release --no-restore'
                echo "✅ Build exitoso"
            }
        }

        // ========================================
        // ETAPA 3: Test + Cobertura (Coverlet)
        // ========================================
        stage('Test') {
            agent {
                docker {
                    image 'mcr.microsoft.com/dotnet/sdk:10.0'
                    reuseNode true
                }
            }
            steps {
                echo "🧪 Ejecutando tests unitarios de ${SERVICE_NAME}..."
                sh 'dotnet test --no-build --configuration Release --logger "trx;LogFileName=test-results.trx" --collect:"XPlat Code Coverage" -- DataCollectionRunSettings.DataCollectors.DataCollector.Configuration.Format=opencover'
                
                // Copiar reporte de cobertura a un lugar predecible para SonarQube
                sh 'mkdir -p notificaciones-service/TestResults'
                sh 'cp -r NotificacionesService.Tests/TestResults/*/coverage.opencover.xml notificaciones-service/TestResults/coverage.opencover.xml || true'
                sh 'ls -l notificaciones-service/TestResults/ || true'
            }
        }

        // ========================================
        // ETAPA 4: SonarQube Analysis
        // ========================================
        stage('SonarQube Analysis') {
            agent {
                docker {
                    image 'sonarsource/sonar-scanner-cli:latest'
                    args '--network proyectofinalmicroservicios_checkin-net'
                    reuseNode true
                }
            }
            steps {
                withSonarQubeEnv('SonarQube') {
                    echo "🔍 Ejecutando análisis SonarQube para ${SERVICE_NAME}..."
                    sh """
                        cd notificaciones-service && \
                        sonar-scanner \
                            -Dsonar.host.url=http://sonarqube:9000 \
                            -Dsonar.token=${SONAR_TOKEN}
                    """
                }
            }
        }

        // ========================================
        // ETAPA 5: Quality Gate
        // ========================================
        stage('Quality Gate') {
            steps {
                echo "🚦 Esperando resultado del Quality Gate..."
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        // ========================================
        // ETAPA 6: Package (Docker Build)
        // ========================================
        stage('Package') {
            steps {
                script {
                    def imageTag = "${env.BUILD_NUMBER}"

                    echo "🐋 Construyendo imagen Docker: ${IMAGE_NAME}:${imageTag}..."
                    sh "docker build -t ${IMAGE_NAME}:${imageTag} -t ${IMAGE_NAME}:latest -f ${SERVICE_NAME}/Dockerfile ${SERVICE_NAME}/"

                    // Verificar que la imagen se construyó
                    sh "docker images ${IMAGE_NAME}:${imageTag}"
                    echo "✅ Imagen construida: ${IMAGE_NAME}:${imageTag}"
                }
            }
        }

        // ========================================
        // ETAPA 7: Publish (Docker Registry)
        // ========================================
        stage('Publish') {
            steps {
                script {
                    def imageTag = "${env.BUILD_NUMBER}"

                    echo "📤 Publicando imagen al registry local..."
                    sh "docker tag ${IMAGE_NAME}:${imageTag} ${REGISTRY}/${IMAGE_NAME}:${imageTag}"
                    sh "docker tag ${IMAGE_NAME}:latest ${REGISTRY}/${IMAGE_NAME}:latest"
                    sh "docker push ${REGISTRY}/${IMAGE_NAME}:${imageTag}"
                    sh "docker push ${REGISTRY}/${IMAGE_NAME}:latest"

                    echo "✅ Imagen publicada: ${REGISTRY}/${IMAGE_NAME}:${imageTag}"
                }
            }
        }

        // ========================================
        // ETAPA 8: E2E Tests (BDD con Behave)
        // ========================================
        stage('E2E Tests') {
            steps {
                echo "🧪 Iniciando pruebas E2E..."

                // Los servicios ya están corriendo en docker-compose
                // Ejecutar suite BDD contra la infraestructura existente
                sh '''
                    docker run --rm \
                        --network proyectofinalmicroservicios_checkin-net \
                        -v $(pwd)/pruebas-funcionales:/app \
                        -w /app \
                        -e AUTH_URL=http://auth-service:80 \
                        -e EMPLEADOS_URL=http://empleados-service:80 \
                        -e DEPARTAMENTOS_URL=http://departamentos-service:8081 \
                        -e NOTIFICACIONES_URL=http://notificaciones-service:8084 \
                        -e PERFILES_URL=http://perfiles-service:8083 \
                        -e ADMIN_USER=admin \
                        -e ADMIN_PASS=admin123 \
                        -e DEFAULT_USER=user \
                        -e DEFAULT_PASS=user123 \
                        python:3.11-slim \
                        bash -c "pip install -r requirements.txt && python -m behave" || true
                '''
            }
        }
    }

    // ========================================
    // POST - Acciones finales
    // ========================================
    post {
        always {
            echo '📋 Pipeline finalizado'
            cleanWs()
        }
        success {
            echo '✅ Pipeline completado exitosamente'
        }
        failure {
            echo '❌ El pipeline ha fallado'
        }
    }
}
